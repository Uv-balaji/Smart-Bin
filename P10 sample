#include <SPI.h>
#include <DMD2.h>
#include <fonts/SystemFont5x7.h>

// panels_wide, panels_high, pin_noe, pin_a, pin_b, pin_latch
SPIDMD dmd(1, 1, 9, 8, 7, 4);

void setup() {
  pinMode(53, OUTPUT);
  digitalWrite(53, HIGH);

  dmd.setBrightness(255);
  dmd.selectFont(SystemFont5x7);
  dmd.begin();

  dmd.drawString(1, 4, "PRABA");
}

void loop() {}
